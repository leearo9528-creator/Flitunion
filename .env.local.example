# 사이트 URL (승인 링크 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://flitunion.com

# Google Analytics
# Google Analytics 콘솔에서 발급한 측정 ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# 문의 폼 → Discord 알림
# 1. Discord 서버 → 알림받을 채널 우측 ⚙️(채널 편집) → 연동 → 웹후크 → 새 웹후크
# 2. 이름/아이콘 설정 후 "웹후크 URL 복사"
# 3. 아래에 붙여넣기 (Vercel 환경변수에도 동일하게 등록)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxxxxxxxxxx/yyyyyyyyyyyyyyyyyyyyyyyyy

# 맞춤 기획안 자동 발송 (Resend)
# 1. https://resend.com 가입 후 도메인 인증 (flitunion.com SPF/DKIM DNS 추가)
# 2. API Keys → Create API Key
# 3. Vercel 환경변수에 동일하게 등록
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# 발신 주소 (도메인 인증 완료된 주소여야 함)
RESEND_FROM_EMAIL=Flit Union <hello@flitunion.com>

# 승인 링크 JWT 서명용 시크릿 (32자 이상 무작위 문자열)
# 생성 예시: openssl rand -base64 48
APPROVAL_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# 카카오 오픈채팅 상담
# https://open.kakao.com/o/sZ5YZ4ni
