# Google Analytics
# Google Analytics 콘솔에서 발급한 측정 ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# 문의 폼 이메일 발송 설정 (Gmail SMTP 기준)
# 1. 구글 계정 > 보안 > 2단계 인증 활성화
# 2. 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
# 3. 아래 값을 채워서 .env.local 로 복사

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=assap.ceo@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=assap.ceo@gmail.com

# 카카오 오픈채팅 상담
